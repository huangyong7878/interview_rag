# OpenAI-compatible API (LLM generation, reranking, validation)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o

# VLM API (vision-language model for PDF page → Markdown)
# 未设置时自动回退到上述 LLM 配置
# VLM_BASE_URL=https://api.openai.com/v1
# VLM_API_KEY=sk-your-key-here
# VLM_MODEL=gpt-4o

# PDF parser priority (comma-separated, tried in order)
# Available: paddleocr, vlm_api, mineru
PARSER_PRIORITY=paddleocr,vlm_api,mineru

# Local embedding model (FlagEmbedding)
# Change to any model supported by FlagEmbedding, e.g. BAAI/bge-large-zh-v1.5
KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
# Set to false to skip FAISS vector index (BM25-only), true for hybrid BM25+vector
ENABLE_FAISS=false

# Application settings
MAX_CHUNK_SIZE=1000
RETRIEVAL_TOP_K=5
